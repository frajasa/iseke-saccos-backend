    accountId: ID!
    debitAmount: Decimal
    creditAmount: Decimal
}

# Dashboard Stats
type DashboardStats {
    totalMembers: Int!
    totalSavings: Decimal!
    activeLoans: Int!
    loanPortfolio: Decimal!
    overdueLoans: Int!
    pendingApplications: Int!
    recentTransactions: [RecentTransaction!]!
}

type RecentTransaction {
    id: ID!
    memberName: String!
    transactionType: String!
    amount: Decimal!
    date: String!
    status: String!
}

# Payment Types
type PaymentRequest {
    id: ID!
    requestNumber: String!
    provider: PaymentProvider!
    direction: PaymentDirection!
    status: PaymentRequestStatus!
    amount: Decimal!
    currency: String!
    phoneNumber: String
    bankAccountNumber: String
    member: Member
    savingsAccount: SavingsAccount
    loanAccount: LoanAccount
    purpose: String
    providerReference: String
    providerConversationId: String
    providerResponseCode: String
    providerResponseMessage: String
    failureReason: String
    retryCount: Int
    initiatedBy: String
    initiatedAt: DateTime!
    sentAt: DateTime
    callbackAt: DateTime
    completedAt: DateTime
    expiresAt: DateTime
}

type PaymentRequestPage {
    content: [PaymentRequest!]!
    totalElements: Int!
    totalPages: Int!
}

type PaymentDashboard {
    totalPaymentsToday: Int!
    completedPayments: Int!
    failedPayments: Int!
    pendingPayments: Int!
    totalAmountToday: Decimal!
    totalCollections: Decimal!
    totalDisbursements: Decimal!
    mpesaCount: Int!
    tigopesaCount: Int!
    nmbCount: Int!
}

# ESS Types
type Employer {
    id: ID!
    employerCode: String!
    employerName: String!
    contactPerson: String
    phoneNumber: String
    email: String
    address: String
    tinNumber: String
    payrollCutoffDay: Int
    isActive: Boolean!
    createdAt: DateTime
    updatedAt: DateTime
}

type PayrollDeduction {
    id: ID!
    member: Member!
    employer: Employer!
    deductionType: String!
    savingsAccount: SavingsAccount
    loanAccount: LoanAccount
    amount: Decimal!
    isActive: Boolean!
    startDate: DateTime
    endDate: DateTime
    description: String
    createdAt: DateTime
}

type PayrollDeductionBatch {
    id: ID!
    batchNumber: String!
    employer: Employer!
    period: String!
    totalDeductions: Int!
    successfulDeductions: Int!
    failedDeductions: Int!
    totalAmount: Decimal!
    status: String!
    processedBy: String
    processedAt: DateTime
    notes: String
    createdAt: DateTime
}

type EssServiceRequest {
    id: ID!
    requestNumber: String!
    member: Member!
    requestType: String!
    status: String!
    amount: Decimal
    description: String
    reviewNotes: String
    reviewedAt: DateTime
    createdAt: DateTime
    updatedAt: DateTime
}

type EssDashboard {
    memberName: String!
    memberNumber: String!
    employerName: String
    totalSavings: Decimal!
    totalLoanOutstanding: Decimal!
    activeLoans: Int!
    activeSavingsAccounts: Int!
    monthlyDeductions: Decimal!
    recentRequests: [EssServiceRequest!]!
}

# Credit Scoring Types
type CreditScoreResult {
    id: ID!
    member: Member!
    score: Int!
    rating: String!
    factors: String
    calculatedAt: DateTime
}

type DividendRun {
    id: ID!
    year: Int!
    method: String!
    rate: Decimal
    totalAmount: Decimal
    membersPaid: Int
    status: String!
    processedBy: String
    processedAt: DateTime
    createdAt: DateTime
}

# Transaction Approval Type
type TransactionApproval {
    id: ID!
    transactionType: String!
    entityId: ID
    amount: Decimal
    requestData: String
    requestedBy: String
    requestedAt: DateTime
    approvedBy: String
    approvedAt: DateTime
    rejectedBy: String
    rejectedAt: DateTime
    rejectionReason: String
    status: ApprovalStatus!
    createdAt: DateTime
    updatedAt: DateTime
}

# Payment Input Types
input MobileDepositInput {
    accountId: ID!
    amount: Decimal!
    provider: PaymentProvider!
    phoneNumber: String!
    description: String
}

input MobileLoanRepaymentInput {
    loanId: ID!
    amount: Decimal!
    provider: PaymentProvider!
    phoneNumber: String!
}

input MobileDisbursementInput {
    loanId: ID!
    amount: Decimal!
    provider: PaymentProvider!
    phoneNumber: String
    bankAccountNumber: String
}
